generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  dailyRecords DailyRecord[]
  products     Product[]
}

model Product {
  id             String        @id @default(cuid())
  name           String
  pvp            Float
  costProduct    Float
  iva            Float         @default(0)
  cpa            Float         @default(0)
  costEnvio      Float
  feeCod         Float
  rateShipping   Float         @default(100)
  rateDelivery   Float         @default(100)
  costReturn     Float         @default(0)
  units          Int           @default(1)
  fixedCostDaily Float         @default(0)
  marginTarget   Float?
  packEnabled    Boolean       @default(false)
  packUnits      Int           @default(2)
  packPvp        Float?
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  dailyRecords2  DailyRecord[] @relation("RecordProduct2")
  dailyRecords   DailyRecord[] @relation("RecordProduct1")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyRecord {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  productId        String
  product2Id       String?
  ordersReceived1  Int      @default(0)
  ordersReceived2  Int      @default(0)
  ordersConfirmed1 Int      @default(0)
  ordersConfirmed2 Int      @default(0)
  ordersShipped    Int      @default(0)
  ordersDelivered1 Int      @default(0)
  ordersDelivered2 Int      @default(0)
  returns          Int      @default(0)
  adsSpend         Float
  fixedCosts       Float    @default(0)
  notes            String?
  orders           Int      @default(0)
  delivered        Int      @default(0)
  rejected         Int      @default(0)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product2         Product? @relation("RecordProduct2", fields: [product2Id], references: [id])
  product          Product  @relation("RecordProduct1", fields: [productId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([userId, date])
}
